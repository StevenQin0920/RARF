{
  "data": {
    "dataset": "PEMS08",
    "num_nodes": 170,
    "target_value_type": "flow"
  },
  "model": {
    "hidden_dim": 64,
    "node_dim": 32,
    "horizon": 12,
    "history_length": 12,
    "dropout": 0.1
  },
  "train": {
    "seed": 1,
    "device": "cuda",
    "epochs": 100,
    "batch_size": 16,
    "learning_rate": 0.001,
    "optimizer": "adamw",
    "weight_decay": 0.0001,
    "fft_loss_weight": 0.01,
    "use_amp": true,
    "use_ema": true,
    "early_stopping_patience": 15
  },
  "output": {
    "root": "output"
  }
}
