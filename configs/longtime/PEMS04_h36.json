{
  "data": {
    "dataset": "PEMS04",
    "num_nodes": 307,
    "target_value_type": "flow",
    "paths": {
      "dataset_root": "longtimeforecasting/h36"
    }
  },
  "model": {
    "hidden_dim": 64,
    "node_dim": 32,
    "horizon": 36,
    "history_length": 36,
    "dropout": 0.1
  },
  "train": {
    "seed": 1,
    "device": "cuda",
    "epochs": 100,
    "batch_size": 16,
    "learning_rate": 0.001,
    "fft_loss_weight": 0.01,
    "optimizer": "adamw",
    "weight_decay": 0.0001,
    "use_amp": true,
    "use_ema": true,
    "early_stopping_patience": 15
  },
  "eval": {
    "report_horizons": [3, 6, 12, 24, 36]
  },
  "output": {
    "root": "output"
  }
}
